# Copy this to .env and fill in your values
# Never commit .env itself

# Flask
SECRET_KEY=change-me-to-a-long-random-string

# Database
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/nova_db
# SQLite (quick local dev — no server needed)
# DATABASE_URL=sqlite:///database.db

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to True when running WITHOUT a Celery worker (local quick-start with SQLite)
CELERY_TASK_ALWAYS_EAGER=False

# Ollama AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
